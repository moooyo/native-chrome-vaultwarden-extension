{
  "manifest_version": 3,
  "key": "",
  "name": "密屿 MiYu",
  "version": "0.0.7",
  "description": "密屿 · 兼容 Bitwarden / Vaultwarden 的原生 MV3 密码管理器。",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "ui/popup/popup.html",
    "default_title": "密屿",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "ui/options/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "alarms",
    "clipboardRead",
    "clipboardWrite",
    "contextMenus",
    "idle",
    "offscreen",
    "activeTab",
    "webNavigation"
  ],
  "host_permissions": [
    "https://api.pwnedpasswords.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/autofill.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/page-webauthn.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/webauthn-bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "commands": {
    "autofill-focused": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "从密屿填充当前聚焦的登录 / 银行卡 / 身份字段"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "ui/fonts/*.woff2"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ]
}
