{
  "manifest_version": 3,
  "name": "Vaultwarden Extension",
  "version": "0.1.0",
  "description": "Native MV3 client for self-hosted Vaultwarden.",
  "background": { "service_worker": "background.js", "type": "module" },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "ui/popup/popup.html",
    "default_title": "Vaultwarden",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": { "page": "ui/options/options.html", "open_in_tab": true },
  "permissions": ["storage", "alarms", "clipboardRead", "clipboardWrite"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/autofill.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/page-webauthn.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/webauthn-bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
