{
  "name": "vaultwarden-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:prod": "node build.mjs --prod && node tools/assert-build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:ui-fixtures": "node tools/build-ui-fixtures.mjs",
    "test:ui": "node tools/build-ui-fixtures.mjs && playwright test",
    "test:ui:update": "node tools/build-ui-fixtures.mjs && playwright test --update-snapshots",
    "lint": "eslint ."
  },
  "dependencies": {
    "lit": "^3.3.3",
    "safe-regex2": "^5.1.1",
    "tldts": "^7.4.8",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@types/webextension-polyfill": "^0.12.5",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
